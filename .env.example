# Google Maps API Key (OPTIONAL - using free Nominatim/OpenStreetMap by default)
# Only needed if you want to use Google Maps instead of Nominatim
# Get from: https://developers.google.com/maps/documentation/geocoding/get-api-key
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Healthdirect API Key (Optional - for GP and pharmacy data)
# Get from: https://developer.healthdirect.gov.au
HEALTHDIRECT_API_KEY=your_healthdirect_api_key_here

# Woolworths API Key (Optional - for supermarket locations)
WOOLWORTHS_API_KEY=your_woolworths_api_key_here

# MyHospitals API Key (Optional - for hospital data)
MYHOSPITALS_API_KEY=your_myhospitals_api_key_here
